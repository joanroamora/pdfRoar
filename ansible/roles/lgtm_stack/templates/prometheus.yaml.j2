global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: 'bastion-node'
    static_configs:
      - targets: ['localhost:9100']

  - job_name: 'k3s-master-node'
    static_configs:
      - targets: ['10.0.10.15:9100']

  - job_name: 'pdf-worker-node'
    static_configs:
      - targets: ['10.0.20.25:9100']

  - job_name: 'pdf-microservices'
    metrics_path: '/metrics'
    static_configs:
      - targets: ['10.0.10.15:8000', '10.0.20.25:8000']
